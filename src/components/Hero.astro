---
const auditEmail = "mailto:rmotteta@gmail.com?subject=Technical%20audit%20request";
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__content">
    <p class="hero__kicker">Senior Fullstack Engineer</p>
    <h1 id="hero-title">I help teams modernize legacy web applications without risky rewrites.</h1>
    <p class="hero__lede">
      Senior fullstack engineer helping companies stabilize, modernize, and improve performance in complex .NET, React, and JavaScript systems.
    </p>
    <div class="hero__actions" aria-label="Primary actions">
      <a class="button button--primary" href={auditEmail}>Request a technical audit</a>
      <a class="button button--secondary" href="#services">View services</a>
    </div>
  </div>
  <aside class="hero__note" aria-label="Consulting focus">
    <p class="hero__note-label">Focused on</p>
    <ul>
      <li>Legacy Web App Modernization</li>
      <li>Complex UI</li>
      <li>Performance-Heavy Web Applications</li>
    </ul>
  </aside>
</section>
